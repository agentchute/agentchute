# Binary build artifacts
/agentchute
/dist/

# OS junk
.DS_Store

# agentchute coordination — live state is transient/local
# Track: loop/README.md, loop/agents/README.md, loop/agents/*.example.md
# Ignore: live registrations, per-recipient inboxes, archives, quarantine
#
# The init marker pair below lets `agentchute init` upgrade the stanza
# idempotently on future runs.

# agentchute-gitignore v3 begin
.agentchute/loop/agents/*.md
!.agentchute/loop/agents/*.example.md
!.agentchute/loop/agents/README.md
.agentchute/loop/inbox/
.agentchute/loop/archive/
.agentchute/loop/malformed/
.agentchute/loop/state/
.agentchute/loop/scratch-*
# agentchute-gitignore v3 end

# Local scratch (spike runs) — never commit
proposal_spike_run/

# Scratch/handoff dir (session-review artifacts, /save-context output) — never commit
.tmp/
